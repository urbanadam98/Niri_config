#!/usr/bin/env python3
"""Syncs TaskNotes pomodoro history into Obsidian vault as clean JSON."""

import json
from datetime import datetime
from pathlib import Path

SRC = Path.home() / "Dokumenty/My_memory/.obsidian/plugins/tasknotes/data.json"
DST = Path.home() / "Dokumenty/My_memory/6_Tools/pomodoro-data.json"

raw = json.loads(SRC.read_text())
history = raw.get("pomodoroHistory", [])

records = []
for entry in history:
    if entry.get("type") != "work":
        continue
    start = entry.get("startTime", "")
    date = start[:10] if start else ""
    task_path = entry.get("taskPath", "")
    task = task_path.split("/")[-1].replace(".md", "") if task_path else ""
    records.append({
        "date": date,
        "startTime": start,
        "endTime": entry.get("endTime", ""),
        "duration": entry.get("plannedDuration", 25),
        "completed": entry.get("completed", False),
        "task": task,
    })

output = {
    "generated": datetime.now().isoformat(timespec="seconds"),
    "source": "tasknotes",
    "records": records,
}

DST.write_text(json.dumps(output, ensure_ascii=False, indent=2))
print(f"Synced {len(records)} records → {DST}")
